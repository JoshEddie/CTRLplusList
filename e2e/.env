# E2E / local-dev Postgres connection — COMMITTED, NON-SECRET test config.
#
# This is the e2e harness's own env file, scoped to e2e/ (NOT the app's root
# env). It is committed on purpose so the localhost test-DB connection has ONE
# home shared by everything that needs it (a TS module, shell scripts, and
# docker-compose cannot otherwise share a literal). It is loaded ONLY by
# explicit path — Next, docker-compose, and dotenv all auto-load the ROOT
# `.env`, never this one. Real secrets live in `*.local` files (gitignored);
# an `e2e/.env.local` here would be ignored (see .gitignore `.env*.local`).
#
# The DB is a throwaway Docker container bound to localhost, and the
# USE_PG_DRIVER boot guard in db/index.ts refuses any non-localhost URL — so
# these values can never reach a real environment.
#
# KEY=VALUE format (dotenv- / shell- / compose-compatible). Consumed by:
#   - scripts/setup-e2e-db.sh / dev-local.sh / test-e2e.sh   (sourced)
#   - docker-compose.e2e.yml                                 (--env-file)
#   - e2e/helpers/constants.ts                               (dotenv.parse)
POSTGRES_USER=e2e
POSTGRES_PASSWORD=e2e_local_test_pw
POSTGRES_DB=ctrlpluslist_e2e
E2E_DB_PORT=5434
DATABASE_URL=postgresql://e2e:e2e_local_test_pw@localhost:5434/ctrlpluslist_e2e?sslmode=disable
