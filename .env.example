# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `.env.example` is committed as the canonical list
# of environment variables the app reads. Keep this file in sync with every
# `process.env.*` reference in the codebase.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Required. Neon Postgres connection string (HTTP driver).
# Format: postgres://USER:PASSWORD@HOST/DB?sslmode=require
# See db/index.ts and CLAUDE.md ("Database driver: no transactions").
DATABASE_URL=

# ---------------------------------------------------------------------------
# Auth (NextAuth v5 + Google OAuth)
# ---------------------------------------------------------------------------

# Required. Google OAuth client credentials.
# Configure at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required in production. NextAuth session-cookie signing secret.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# DEV ONLY auth bypass â€” no env var to set here anymore. Run `npm run dev:local`
# instead: it sets `USE_PG_DRIVER=1` (localhost Docker Postgres + synthesized
# sessions, no real OAuth). The session identity is chosen by `BYPASS_SESSION_USER`
# (unset â‡’ `dev-test-viewer`; `guest` â‡’ no session). The bypass is scoped to a
# localhost DB by the boot guard in db/index.ts. See CLAUDE.md ("Local dev + e2e
# auth bypass") and scripts/seed-dev-users.ts.

# ---------------------------------------------------------------------------
# Image search (/api/image-search)
# ---------------------------------------------------------------------------

# Optional. Comma-separated provider chain, tried in order on quota/error.
# Accepted values: `serpapi`, `serper`, `mock`. Example: `serpapi,serper,mock`.
# Falls back to a sensible default if unset.
IMAGE_SEARCH_PROVIDERS=

# Optional. Legacy single-provider override. Prefer IMAGE_SEARCH_PROVIDERS.
IMAGE_SEARCH_PROVIDER=

# Optional, dev convenience. When `true`, all providers return mock results
# without making outbound HTTP calls.
IMAGE_SEARCH_USE_MOCK=

# Optional, dev convenience. When `true`, the next request returns a
# simulated `quota_exceeded` from the upstream provider â€” distinct from the
# per-user `rate_limited` shape. Used to exercise both 429 code paths.
IMAGE_SEARCH_SIMULATE_QUOTA=

# Required when `serpapi` is in the provider chain.
SERPAPI_API_KEY=

# Required when `serper` is in the provider chain.
SERPER_API_KEY=

# ---------------------------------------------------------------------------
# Product fetch (/api/product-fetch)
# ---------------------------------------------------------------------------

# Optional. Zyte extract API key (https://www.zyte.com) â€” tier 2 of the
# paste-link product fetch, used only when the free tier-1 parse yields no
# title. Paid, pay-as-you-go. When unset the waterfall skips Zyte entirely, so
# local dev and e2e never need it. Lives in Vercel env + this gitignored
# `.env*.local` only â€” never in `e2e/.env`. See lib/product-fetch/zyte.ts.
ZYTE_API_KEY=
